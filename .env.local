# Frontend Environment Variables
APP_ENV=DEV

# API Base URLs
NEXT_PUBLIC_BK_DEV_API_URL=http://localhost:8000/api
NEXT_PUBLIC_BK_UAT_API_URL=https://api-uat.bondkonnect.com/api
NEXT_PUBLIC_BK_PROD_API_URL=https://api.bondkonnect.com/api

# WebSocket URLs
NEXT_PUBLIC_BK_DEV_WEBSOCKET_API_URL=http://localhost:8000
NEXT_PUBLIC_BK_UAT_WEBSOCKET_API_URL=https://api-uat.bondkonnect.com
NEXT_PUBLIC_BK_PROD_WEBSOCKET_API_URL=https://api.bondkonnect.com

# Standard API URL (fallback)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:4000

# Pusher Configuration
NEXT_PUBLIC_PUSHER_APP_KEY=
NEXT_PUBLIC_PUSHER_APP_CLUSTER=mt1

# Other
NEXT_PUBLIC_Ocp_Apim_Subscription_Key=
NEXT_PUBLIC_LOGIN_URL=http://localhost:4000/login
