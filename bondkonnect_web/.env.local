# Frontend Port
PORT=4000

# API Configuration
# If using 'php artisan serve', use http://localhost:8000/api
# If using Laragon virtual hosts, use http://bondkonnect_api.test/api
# If using Laragon default path, use http://localhost/bondkonnect_api/public/api

NEXT_PUBLIC_BK_DEV_API_URL=http://localhost:8000/api
NEXT_PUBLIC_BK_UAT_API_URL=http://localhost:8000/api
NEXT_PUBLIC_BK_PROD_API_URL=http://localhost:8000/api

APP_ENV=development

# If the above fails, try changing localhost:8000 to your Laragon URL

# Pusher / WebSocket Configuration
NEXT_PUBLIC_PUSHER_APP_KEY=your_pusher_app_key_here
NEXT_PUBLIC_PUSHER_APP_CLUSTER=ap2

