APP_NAME=BondKonnect
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Primary Database (Railway PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=
DB_SSLMODE=require
DATABASE_URL=

# Legacy/Secondary Connection Variables
BK_API_DB_DRIVER=pgsql
BK_DB_DRIVER=pgsql
BK_HOST=
BK_PORT=5432
BK_DATABASE=
BK_USERNAME=
BK_PASSWORD=
BK_API_DB_SSLMODE=require
BK_DB_SSLMODE=require

# Primary Redis (Railway Redis)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Laravel Service Drivers
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

MEMCACHED_HOST=127.0.0.1

FILESYSTEM_DISK=local

# Broadcaster (Pusher)
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=eu

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
